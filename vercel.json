{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "outputDirectory": "static-build",
  "rewrites": [
    { "source": "/android", "destination": "/android/manifest.json" },
    { "source": "/ios", "destination": "/ios/manifest.json" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
